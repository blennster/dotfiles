{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "mode": "primary",
      "prompt": "{file:./system.md}",
      "temperature": 0.2,
      // "steps": 20
    },
    "yolo": {
      "mode": "primary",
      "prompt": "{file:./system.md}",
      "temperature": 0.6,
      "top_p": 0.5
    }
  },
  "plugin": [
    "@cortexkit/opencode-magic-context@latest"
  ],
  "mcp": {
    "serial": {
      "type": "local",
      "command": [
        "/Users/now/Private/serial-mcp/serial-mcp"
      ],
      "enabled": true
    }
  },
  "compaction": {
    "auto": false,
    "prune": false
  }
}
