{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "formatter": {
    "prettier": {
      "command": [
        "npx",
        "prettier",
        "--write",
        "$FILE"
      ],
      "extensions": [
        ".md",
      ]
    },
  },
  "mcp": {
    "nordicsemi": {
      "type": "remote",
      "enabled": true,
      "url": "https://nordicsemi.mcp.kapa.ai"
    },
    "azure-devops": {
      "type": "local",
      "enabled": false,
      "command": [
        "npx",
        "-y",
        "@azure-devops/mcp",
        "Svep",
        "-s"
      ],
    },
  },
}
